programa {
  funcao inicio() { 
    inteiro a,b, c
    escreva ("informe o valor a: ")
    leia(a)

    escreva("informe o valor b: ")
    leia(b) 

    se (a==b){
      c = a + b
    
    escreva("valor de c: ", c)  
    } senao {
      c = a * b

      escreva("valo de c: ", c) 
    }

    
  }
}
