programa {
  funcao inicio() {
    inteiro i, numero, soma = 0 

    para(inteiro i = 1; i <= 5; i++) {
      escreva("imnforme o numero para ser somado: ")
      leia(numero)

      soma = soma + numero
    }

    escreva(" resultado da soma: ", soma, "\n")



      
      

    

    




    

  }
}
